# Omega Tutor V1 — copy to .env and fill

# Database (Postgres). Create DB first if using existing Postgres:
#   psql "postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/postgres" -c "CREATE DATABASE omega_tutor;"
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/omega_tutor

# Optional: learner auth (V1 can be anonymous)
# NEXT_PUBLIC_ANONYMOUS_LEARNER=true

# LLM provider (V1: abstract boundary; set for your provider)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Config version defaults (can override via ConfigVersion table)
# GATING_MIN_OBSERVATIONS=3
# GATING_MATCH_STRENGTH_THRESHOLD=0.7
# CONFIDENCE_HALF_LIFE_DAYS=14
# SCHEDULER_PROBE_RATIO_CAP=0.33
# SCHEDULER_MIN_MINUTES_BETWEEN=2
