# For standalone deployment. Claude.ai artifacts proxy the API; no key in code.
# Local dev: Vite proxies /api/anthropic/* so the key is read here and never sent to the browser (avoids CORS).
# Production: run a backend that proxies to Anthropic (e.g. Vercel serverless function) and point the app at /api/anthropic/...
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Set to "true" to use deterministic mock data instead of API calls
VITE_DETERMINISTIC=false
